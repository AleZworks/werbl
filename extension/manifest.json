{
  "manifest_version": 3,
  "name": "Werbl",
  "version": "0.1.0",
  "description": "Right-click images and save them as PNG, JPG, or WebP without uploading them.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["contextMenus", "downloads", "offscreen", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "Werbl",
    "default_popup": "popup.html"
  }
}
